# Puerto del servidor
PORT=3000

# --- WhatsApp Business Cloud API (Meta) ---
# Token permanente o temporal generado en developers.facebook.com
WHATSAPP_TOKEN=
# ID del numero de telefono de WhatsApp Business (Phone Number ID)
WHATSAPP_PHONE_NUMBER_ID=
# Token que tu defines y usas para verificar el webhook en Meta (cualquier cadena secreta)
WHATSAPP_VERIFY_TOKEN=cambia_este_token

# Token simple para proteger el panel de escaneo (login basico)
APP_TOKEN=cambia_este_token_admin
