# Puerto del servidor
PORT=3000

# Cadena de conexion a PostgreSQL
DATABASE_URL=postgres://usuario:password@localhost:5432/sistema_guias

# --- WhatsApp Business Cloud API (Meta) ---
# Token permanente o temporal generado en developers.facebook.com
WHATSAPP_TOKEN=
# ID del numero de telefono de WhatsApp Business (Phone Number ID)
WHATSAPP_PHONE_NUMBER_ID=
# Token que tu defines y usas para verificar el webhook en Meta (cualquier cadena secreta)
WHATSAPP_VERIFY_TOKEN=cambia_este_token

# --- Login del panel ---
# Usuario administrador inicial (se crea solo si aun no existe ningun usuario)
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esta_contrasena
# Horas que dura una sesion antes de pedir login de nuevo (12 por defecto)
SESSION_HOURS=12

# (Opcional, legado) Token simple para integraciones tipo pistola de escaneo.
# Se sigue aceptando en el header X-App-Token ademas del login con usuario.
APP_TOKEN=
